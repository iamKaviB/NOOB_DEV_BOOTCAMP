              "raw": "{{baseUrl}}/api/products",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products"]
            },
            "description": "Returns all products as List<ProductResponseDTO>.\n\nNote: ProductResponseDTO does NOT include the 'orders' field — this intentionally breaks the Product <-> Order circular reference that would occur if entities were serialised directly."
          },
          "response": [
            {
              "name": "200 OK",
              "originalRequest": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/products",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "products"]
                }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "[\n  {\n    \"id\": 1,\n    \"name\": \"MacBook Pro\",\n    \"price\": 1999.99\n  },\n  {\n    \"id\": 2,\n    \"name\": \"Magic Mouse\",\n    \"price\": 79.99\n  }\n]"
